# Riverviews environment variables
# Copy to .env and fill in secrets before running docker compose.
# NEVER commit .env to version control.

# PostgreSQL superuser password (used only internally by the postgres container)
POSTGRES_SUPERUSER_PASSWORD=change_me_super

# Password for the flopro_admin application role
FLOPRO_ADMIN_PASSWORD=change_me_app

# Twilio credentials (for sms_gateway)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+15555550199
